                ],
                "jaeger": [
                  "jaeger"
                ],
                "loki": [
                  "loki"
                ],
                "mysql": [
                  "mysql"
                ],
                "opensearch": [
                  "opensearch"
                ],
                "postgres": [
                  "postgres"
                ],
                "postgrest": [
                  "http"
                ],
                "prometheus": [
                  "prometheus"
                ],
                "sql": [
                  "postgres",
                  "mysql",
                  "sql_server",
                  "clickhouse"
                ],
                "sqlserver": [
                  "sql_server"
                ]
              },
              "param": "types"
            },
            "searchParam": "__lookup_q",
            "url": "/api/v1/connection"
          }
        },
        "options": {
          "title": "Options",
          "type": "object"
        },
        "type": {
          "enum": [
            "sql",
            "postgres",
            "mysql",
