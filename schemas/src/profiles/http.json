{
  "$id": "http.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "connection": {
      "description": "Pick a saved connection or type an inline DSN/URL",
      "title": "Connection",
      "type": "string",
      "x-clicky-lookup": {
        "filter": "connection",
        "multi": false,
        "scope": {
          "from": "provider.type",
          "map": {
            "clickhouse": [
              "clickhouse"
            ],
            "http": [
              "http"
            ],
            "jaeger": [
              "jaeger"
            ],
            "loki": [
              "loki"
            ],
            "mysql": [
              "mysql"
            ],
            "opensearch": [
              "opensearch"
            ],
            "opentelemetry": [
              "opentelemetry"
            ],
            "postgres": [
              "postgres"
            ],
            "postgrest": [
              "http"
            ],
            "prometheus": [
              "prometheus"
            ],
            "sql": [
              "postgres",
              "mysql",
              "sql_server",
              "clickhouse"
            ],
            "sqlserver": [
              "sql_server"
            ]
          },
          "param": "types"
        },
        "searchParam": "__lookup_q",
        "url": "/api/v1/connection"
      }
    },
    "options": {
      "properties": {
        "body": {
          "format": "textarea",
          "title": "Body",
          "type": "string"
        },
        "jsonpath": {
          "description": "Extract rows from a wrapped JSON response",
          "title": "JSONPath",
          "type": "string"
        },
        "method": {
          "enum": [
            "GET",
            "POST",
            "PUT",
            "PATCH",
            "DELETE"
          ],
          "title": "Method",
          "type": "string"
        },
        "url": {
          "description": "Inline HTTP base URL used instead of a saved connection",
          "title": "Base URL",
          "type": "string",
          "x-clicky-component": "k8s-url-selector",
          "x-clicky-default-source": "value"
        }
      },
      "title": "Options",
      "type": "object"
    },
    "type": {
      "const": "http",
      "title": "Type",
      "type": "string"
    }
  },
  "required": [
    "type"
  ],
  "title": "Query provider: http",
  "type": "object"
}
