{
  "$id": "sql.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "connection": {
      "description": "Pick a saved connection or type an inline DSN/URL",
      "title": "Connection",
      "type": "string",
      "x-clicky-lookup": {
        "filter": "connection",
        "multi": false,
        "scope": {
          "from": "provider.type",
          "map": {
            "clickhouse": [
              "clickhouse"
            ],
            "http": [
              "http"
            ],
            "jaeger": [
              "jaeger"
            ],
            "loki": [
              "loki"
            ],
            "mysql": [
              "mysql"
            ],
            "opensearch": [
              "opensearch"
            ],
            "postgres": [
              "postgres"
            ],
            "postgrest": [
              "http"
            ],
            "prometheus": [
              "prometheus"
            ],
            "sql": [
              "postgres",
              "mysql",
              "sql_server",
              "clickhouse"
            ],
            "sqlserver": [
              "sql_server"
            ]
          },
          "param": "types"
        },
        "searchParam": "__lookup_q",
        "url": "/api/v1/connection"
      }
    },
    "options": {
      "properties": {
        "type": {
          "enum": [
            "postgres",
            "mysql",
            "sql_server",
            "clickhouse"
          ],
          "title": "Driver",
          "type": "string",
          "x-enum-display": "combobox",
          "x-enum-icons": {
            "clickhouse": "clickhouse",
            "mysql": "mysql",
            "postgres": "postgres",
            "sql_server": "sqlserver"
          }
        },
        "url": {
          "description": "Inline database URL used instead of a saved connection",
          "title": "URL / DSN",
          "type": "string",
          "x-clicky-component": "k8s-url-selector",
          "x-clicky-default-source": "value"
        }
      },
      "title": "Options",
      "type": "object"
    },
    "type": {
      "const": "sql",
      "title": "Type",
      "type": "string"
    }
  },
  "required": [
    "type"
  ],
  "title": "Query provider: sql",
  "type": "object"
}
