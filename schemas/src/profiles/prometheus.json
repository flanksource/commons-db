{
  "$id": "prometheus.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "connection": {
      "description": "Pick a saved connection or type an inline DSN/URL",
      "title": "Connection",
      "type": "string",
      "x-clicky-lookup": {
        "filter": "connection",
        "multi": false,
        "scope": {
          "from": "provider.type",
          "map": {
            "clickhouse": [
              "clickhouse"
            ],
            "http": [
              "http"
            ],
            "jaeger": [
              "jaeger"
            ],
            "loki": [
              "loki"
            ],
            "mysql": [
              "mysql"
            ],
            "opensearch": [
              "opensearch"
            ],
            "opentelemetry": [
              "opentelemetry"
            ],
            "postgres": [
              "postgres"
            ],
            "postgrest": [
              "http"
            ],
            "prometheus": [
              "prometheus"
            ],
            "sql": [
              "postgres",
              "mysql",
              "sql_server",
              "clickhouse"
            ],
            "sqlserver": [
              "sql_server"
            ]
          },
          "param": "types"
        },
        "searchParam": "__lookup_q",
        "url": "/api/v1/connection"
      }
    },
    "options": {
      "properties": {
        "range": {
          "properties": {
            "end": {
              "description": "Date math, for example now",
              "title": "End",
              "type": "string"
            },
            "start": {
              "description": "Date math, for example now-1h",
              "title": "Start",
              "type": "string"
            },
            "step": {
              "description": "Sample step, for example 30s",
              "title": "Step",
              "type": "string"
            }
          },
          "title": "Range",
          "type": "object"
        },
        "selectLabels": {
          "items": {
            "type": "string"
          },
          "title": "Select labels",
          "type": "array"
        },
        "url": {
          "description": "Inline Prometheus URL used instead of a saved connection",
          "title": "URL",
          "type": "string",
          "x-clicky-component": "k8s-url-selector",
          "x-clicky-default-source": "value"
        }
      },
      "title": "Options",
      "type": "object"
    },
    "type": {
      "const": "prometheus",
      "title": "Type",
      "type": "string"
    }
  },
  "required": [
    "type"
  ],
  "title": "Query provider: prometheus",
  "type": "object"
}
