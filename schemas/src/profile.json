            "mysql": "mysql",
            "opensearch": "opensearch",
            "opentelemetry": "opentelemetry",
            "postgres": "postgres",
            "postgrest": "globe",
            "prometheus": "prometheus",
            "sql": "database",
            "sqlserver": "sqlserver"
